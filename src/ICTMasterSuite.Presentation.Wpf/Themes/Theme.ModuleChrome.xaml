<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="PremiumDataGridStyle" TargetType="DataGrid">
        <Setter Property="Background" Value="#14000000" />
        <Setter Property="BorderBrush" Value="#33FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowBackground" Value="Transparent" />
        <Setter Property="AlternatingRowBackground" Value="#0CFFFFFF" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="HorizontalGridLinesBrush" Value="#22FFFFFF" />
        <Setter Property="RowHeight" Value="32" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="ModuleStatusBarTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,10,0,0" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="EmptyStateBannerStyle" TargetType="Border">
        <Setter Property="Background" Value="#140EA5E9" />
        <Setter Property="BorderBrush" Value="#330EA5E9" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="LoadingOverlayStyle" TargetType="Border">
        <Setter Property="Background" Value="#990F172A" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
</ResourceDictionary>
