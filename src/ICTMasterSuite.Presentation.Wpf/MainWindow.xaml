<Window x:Class="ICTMasterSuite.Presentation.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ICT Master Suite"
        Height="720"
        Width="1280"
        MinHeight="600"
        MinWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" Padding="10">
            <TextBlock Text="ICT Master Suite"
                       Style="{DynamicResource TitleTextStyle}" />
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" Padding="10" Margin="8">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="Arquitetura premium WPF + MVVM" Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Text="{Binding LoggedUserLabel}" Margin="0,8,0,8" Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Text="{Binding SessionStatusLabel}" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,8" />
                    <Button Content="Entrar"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding CanAuthenticate}"
                            Visibility="{Binding CanShowLoginAction, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Content="Logout"
                            Command="{Binding LogoutCommand}"
                            Margin="0,6,0,0"
                            Visibility="{Binding CanShowLogoutAction, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Content="Atualizar conectividade"
                            Command="{Binding RefreshConnectivityCommand}"
                            Margin="0,6,0,0" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Modules}"
                         SelectedItem="{Binding SelectedModule}"
                         DisplayMemberPath="Title"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource PrimaryTextBrush}" />
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Padding="10" Margin="8" Background="{DynamicResource AppBackgroundBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Margin="0,0,0,12"
                        Padding="12,10"
                        CornerRadius="10"
                        Background="#1F0EA5E9"
                        Visibility="{Binding IsRestrictedMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Modo visitante/offline ativo"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                        <TextBlock Text="{Binding RestrictedModeMessage}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource MutedTextBrush}" />
                    </StackPanel>
                </Border>
                <TextBlock Text="{Binding SelectedModule.Title}" Style="{DynamicResource HeaderTextStyle}" />
                <TextBlock Text="{Binding SelectedModule.Description}" Margin="0,8,0,16" Foreground="{DynamicResource MutedTextBrush}" />
                <Grid Margin="0,16,0,0" Visibility="{Binding SelectedModule.Module, Converter={StaticResource ModuleVisibilityConverter}, ConverterParameter=Authentication}">
                    <Border Style="{DynamicResource PremiumCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Acesso avançado"
                                       Style="{DynamicResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="Faça login para liberar gravação de análises, histórico técnico, base de conhecimento, relatórios persistentes, updater e gestão de usuários." />
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Style="{DynamicResource SoftButtonStyle}"
                                        Content="Entrar agora"
                                        Command="{Binding LoginCommand}"
                                        IsEnabled="{Binding CanAuthenticate}" />
                                <Button Margin="8,0,0,0"
                                        Style="{DynamicResource SoftButtonStyle}"
                                        Content="Revalidar conectividade"
                                        Command="{Binding RefreshConnectivityCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
                <Grid Visibility="{Binding SelectedModule.Module, Converter={StaticResource ModuleVisibilityConverter}, ConverterParameter=UsersAndProfiles}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="220" Text="{Binding UserManagement.SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Margin="8,0,0,0" Content="Buscar" Command="{Binding UserManagement.SearchCommand}" />
                        <Button Margin="8,0,0,0" Content="Salvar" Command="{Binding UserManagement.UpdateSelectedCommand}" />
                        <Button Margin="8,0,0,0" Content="Criar" Command="{Binding UserManagement.CreateUserCommand}" />
                        <Button Margin="8,0,0,0" Content="Ativar/Inativar" Command="{Binding UserManagement.ToggleSelectedStatusCommand}" />
                    </StackPanel>
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <DataGrid Style="{DynamicResource PremiumDataGridStyle}"
                                  ItemsSource="{Binding UserManagement.Users}"
                                  SelectedItem="{Binding UserManagement.SelectedUser}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Margin="8"
                                  VerticalAlignment="Stretch">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nome" Binding="{Binding FullName}" Width="*" />
                                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*" />
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                                <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding IsActive}" Width="80" />
                                <DataGridTextColumn Header="Perfil" Binding="{Binding RoleName}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Nome completo" />
                            <TextBox Text="{Binding UserManagement.FullNameInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                            <TextBlock Text="Username" />
                            <TextBox Text="{Binding UserManagement.UsernameInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                            <TextBlock Text="Email" />
                            <TextBox Text="{Binding UserManagement.EmailInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                            <TextBlock Text="Senha inicial/reset" />
                            <TextBox Text="{Binding UserManagement.PasswordInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Style="{DynamicResource ModuleStatusBarTextStyle}"
                               Visibility="{Binding SelectedModule.Module, Converter={StaticResource ModuleVisibilityConverter}, ConverterParameter=UsersAndProfiles}"
                               Text="{Binding UserManagement.StatusMessage}" />
                </Grid>
                <Grid Margin="0,16,0,0" Visibility="{Binding SelectedModule.Module, Converter={StaticResource ModuleVisibilityConverter}, ConverterParameter=LogFinder}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="220" Text="{Binding LogSearch.SearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Margin="8,0,0,0" Width="380" Text="{Binding LogSearch.DirectoryInput, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Adicionar Diretório" Command="{Binding LogSearch.AddDirectoryCommand}" />
                        <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Pesquisar" Command="{Binding LogSearch.SearchCommand}" />
                    </StackPanel>
                    <Border Grid.Row="1" Margin="0,6,0,6" Padding="10" Background="#14F59E0B" CornerRadius="8" Visibility="{Binding LogSearch.HasPreviousHistory, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Foreground="#FFFCD34D">Atenção: este serial já possui histórico técnico anterior.</TextBlock>
                    </Border>

                    <ItemsControl Grid.Row="1" Margin="0,28,0,8" ItemsSource="{Binding LogSearch.Directories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,2,0,2">
                                    <Button DockPanel.Dock="Right"
                                            Content="X"
                                            Style="{DynamicResource SoftButtonStyle}"
                                            Command="{Binding DataContext.LogSearch.RemoveDirectoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                    <TextBlock Text="{Binding}" Foreground="{DynamicResource MutedTextBrush}" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Grid.Row="2" MinHeight="240">
                        <DataGrid Style="{DynamicResource PremiumDataGridStyle}"
                                  ItemsSource="{Binding LogSearch.Results}"
                                  SelectedItem="{Binding LogSearch.SelectedResult}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Margin="8"
                                  VerticalAlignment="Stretch">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Arquivo" Binding="{Binding FileName}" Width="*" />
                                <DataGridTextColumn Header="Tipo" Binding="{Binding SourceType}" Width="100" />
                                <DataGridTextColumn Header="Resultado" Binding="{Binding Result}" Width="100" />
                                <DataGridTextColumn Header="Serial" Binding="{Binding SerialNumber}" Width="150" />
                                <DataGridTextColumn Header="Modelo" Binding="{Binding Model}" Width="150" />
                                <DataGridTextColumn Header="Estação" Binding="{Binding Station}" Width="130" />
                                <DataGridTextColumn Header="Timestamp" Binding="{Binding LogTimestamp}" Width="160" />
                                <DataGridTextColumn Header="Erro" Binding="{Binding ErrorCode}" Width="120" />
                                <DataGridTextColumn Header="Descrição Erro" Binding="{Binding ErrorDescription}" Width="2*" />
                                <DataGridTextColumn Header="Resumo" Binding="{Binding Summary}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Style="{DynamicResource LoadingOverlayStyle}"
                                Visibility="{Binding LogSearch.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Analisando logs e aplicando o parser..."
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                        </Border>
                        <Border Style="{DynamicResource EmptyStateBannerStyle}"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Stretch"
                                Margin="12,12,12,0"
                                Visibility="{Binding LogSearch.ShowFinderEmptyBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Nenhum resultado na grade. Adicione diretórios válidos e execute uma pesquisa."
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0">
                        <Button Style="{DynamicResource SoftButtonStyle}" Content="Registrar análise" Command="{Binding LogSearch.RegisterAnalysisCommand}" IsEnabled="{Binding CanUseRestrictedFinderActions}" />
                        <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Ver histórico" Command="{Binding LogSearch.OpenHistoryCommand}" IsEnabled="{Binding CanUseRestrictedFinderActions}" />
                        <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Conhecimento relacionado" Command="{Binding LogSearch.SearchRelatedKnowledgeCommand}" IsEnabled="{Binding CanUseRestrictedFinderActions}" />
                    </StackPanel>
                </Grid>
                <Grid Margin="0,16,0,0" Visibility="{Binding SelectedModule.Module, Converter={StaticResource ModuleVisibilityConverter}, ConverterParameter=TechnicalHistory}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{DynamicResource PremiumCardStyle}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="Histórico por Serial" Style="{DynamicResource SectionTitleTextStyle}" VerticalAlignment="Center" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <TextBox Width="240" Text="{Binding TechnicalHistory.SerialSearch, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Buscar Histórico" Command="{Binding TechnicalHistory.SearchCommand}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                        <Border Style="{DynamicResource EmptyStateBannerStyle}"
                                Visibility="{Binding TechnicalHistory.ShowHistoryGridEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Nenhuma análise listada para o serial informado."
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Border>
                        <DataGrid Style="{DynamicResource PremiumDataGridStyle}"
                                  MinHeight="200"
                                  ItemsSource="{Binding TechnicalHistory.Analyses}"
                                  SelectedItem="{Binding TechnicalHistory.SelectedAnalysis}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Margin="8"
                                  VerticalAlignment="Stretch">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data" Binding="{Binding CreatedAt}" Width="150" />
                                <DataGridTextColumn Header="Serial" Binding="{Binding SerialNumber}" Width="120" />
                                <DataGridTextColumn Header="Modelo" Binding="{Binding Model}" Width="120" />
                                <DataGridTextColumn Header="Resultado" Binding="{Binding Result}" Width="90" />
                                <DataGridTextColumn Header="Erro" Binding="{Binding ErrorCode}" Width="100" />
                                <DataGridTextColumn Header="Resumo" Binding="{Binding Summary}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        </StackPanel>
                        <Border Grid.Column="1" Margin="12,0,0,0" Style="{DynamicResource PremiumCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Detalhe da análise" Style="{DynamicResource SectionTitleTextStyle}" />
                                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource MutedTextBrush}" Text="{Binding TechnicalHistory.SelectedAnalysis.CreatedAt, StringFormat='Data: {0:dd/MM/yyyy HH:mm}'}" />
                                <TextBlock Foreground="{DynamicResource MutedTextBrush}" Text="{Binding TechnicalHistory.SelectedAnalysis.TechnicianName, StringFormat='Técnico: {0}'}" />
                                <TextBlock Foreground="{DynamicResource MutedTextBrush}" Text="{Binding TechnicalHistory.SelectedAnalysis.ErrorCode, StringFormat='Erro: {0}'}" />
                                <TextBlock Text="{Binding TechnicalHistory.SelectedAnalysis.Summary}" Margin="0,10,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding TechnicalHistory.SelectedAnalysis.AnalysisText}" TextWrapping="Wrap" Margin="0,10,0,0" />
                                <TextBlock Margin="0,14,0,0"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           Visibility="{Binding TechnicalHistory.ShowSelectionPlaceholder, Converter={StaticResource BooleanToVisibilityConverter}}"
                                           Text="Selecione uma linha na grade para ver o detalhe." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
                <Grid Margin="0,16,0,0" Visibility="{Binding SelectedModule.Module, Converter={StaticResource ModuleVisibilityConverter}, ConverterParameter=KnowledgeBase}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{DynamicResource PremiumCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Busca de Base de Conhecimento" Style="{DynamicResource SectionTitleTextStyle}" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <TextBox Width="150" Text="{Binding KnowledgeBase.ModelSearch, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="8,0,0,0" Width="150" Text="{Binding KnowledgeBase.TestPhaseSearch, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="8,0,0,0" Width="240" Text="{Binding KnowledgeBase.TermSearch, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Buscar artigos" Command="{Binding KnowledgeBase.SearchCommand}" />
                                <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Criar" Command="{Binding KnowledgeBase.CreateCommand}" />
                                <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Salvar edição" Command="{Binding KnowledgeBase.UpdateSelectedCommand}" />
                                <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Ativar/Inativar" Command="{Binding KnowledgeBase.ToggleActiveSelectedCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                        <Border Style="{DynamicResource EmptyStateBannerStyle}"
                                Visibility="{Binding KnowledgeBase.ShowKbEmptyBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Nenhum artigo encontrado para os filtros atuais."
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Border>
                        <DataGrid Style="{DynamicResource PremiumDataGridStyle}"
                                  MinHeight="200"
                                  ItemsSource="{Binding KnowledgeBase.Articles}"
                                  SelectedItem="{Binding KnowledgeBase.SelectedArticle}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Margin="8"
                                  VerticalAlignment="Stretch">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Modelo" Binding="{Binding Model}" Width="120" />
                                <DataGridTextColumn Header="Fase" Binding="{Binding TestPhase}" Width="120" />
                                <DataGridTextColumn Header="Sintoma" Binding="{Binding Symptom}" Width="*" />
                                <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding IsActive}" Width="70" />
                            </DataGrid.Columns>
                        </DataGrid>
                        </StackPanel>
                        <Border Grid.Column="1" Margin="12,0,0,0" Style="{DynamicResource PremiumCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Editor de Artigo" Style="{DynamicResource SectionTitleTextStyle}" />
                                <TextBlock Text="Modelo" Margin="0,8,0,0" />
                                <TextBox Text="{Binding KnowledgeBase.ModelInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                                <TextBlock Text="Fase de teste" />
                                <TextBox Text="{Binding KnowledgeBase.TestPhaseInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                                <TextBlock Text="Sintoma" />
                                <TextBox Text="{Binding KnowledgeBase.SymptomInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                                <TextBlock Text="Solução" />
                                <TextBox Text="{Binding KnowledgeBase.SolutionInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                                <TextBlock Text="Autor" />
                                <TextBox Text="{Binding KnowledgeBase.AuthorInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
                <Grid Margin="0,16,0,0" Visibility="{Binding SelectedModule.Module, Converter={StaticResource ModuleVisibilityConverter}, ConverterParameter=Export}">
                    <Border Style="{DynamicResource PremiumCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Relatórios Técnicos" Style="{DynamicResource SectionTitleTextStyle}" />

                            <StackPanel Grid.Row="1" Margin="0,10,0,0" Orientation="Horizontal">
                                <TextBox Width="220" Text="{Binding Reports.SerialInput, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Histórico Excel" Command="{Binding Reports.ExportTechnicalHistoryExcelCommand}" />
                                <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Histórico PDF" Command="{Binding Reports.ExportTechnicalHistoryPdfCommand}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,10,0,0" Orientation="Horizontal">
                                <TextBox Width="130" Text="{Binding Reports.ModelFilter, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="8,0,0,0" Width="130" Text="{Binding Reports.PhaseFilter, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="8,0,0,0" Width="200" Text="{Binding Reports.TermFilter, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Base Excel" Command="{Binding Reports.ExportKnowledgeBaseExcelCommand}" />
                                <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Base PDF" Command="{Binding Reports.ExportKnowledgeBasePdfCommand}" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Margin="0,10,0,0" Orientation="Horizontal">
                                <Button Style="{DynamicResource SoftButtonStyle}" Content="Finder Excel" Command="{Binding Reports.ExportFinderExcelCommand}" />
                                <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Finder PDF" Command="{Binding Reports.ExportFinderPdfCommand}" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Margin="0,10,0,0">
                                <ProgressBar Height="3"
                                             IsIndeterminate="True"
                                             Visibility="{Binding Reports.IsExporting, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock Style="{DynamicResource ModuleStatusBarTextStyle}"
                                           Margin="0,6,0,0"
                                           Text="{Binding Reports.StatusMessage}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
                <Grid Margin="0,16,0,0" Visibility="{Binding SelectedModule.Module, Converter={StaticResource ModuleVisibilityConverter}, ConverterParameter=Audit}">
                    <StackPanel>
                        <TextBlock Text="Dashboard Executivo/Técnico" Style="{DynamicResource SectionTitleTextStyle}" />
                        <WrapPanel Margin="0,10,0,0">
                            <Border Style="{DynamicResource PremiumCardStyle}" Width="230" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="Análises Técnicas" Foreground="{DynamicResource MutedTextBrush}" />
                                    <TextBlock Text="{Binding Dashboard.TotalAnalyses}" FontSize="30" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                            <Border Style="{DynamicResource PremiumCardStyle}" Width="230" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="Artigos Ativos" Foreground="{DynamicResource MutedTextBrush}" />
                                    <TextBlock Text="{Binding Dashboard.ActiveArticles}" FontSize="30" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                            <Border Style="{DynamicResource PremiumCardStyle}" Width="230" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="FAIL / PASS" Foreground="{DynamicResource MutedTextBrush}" />
                                    <TextBlock Text="{Binding Dashboard.FailCount}" FontSize="24" FontWeight="Bold" Foreground="#FFF87171" />
                                    <TextBlock Text="{Binding Dashboard.PassCount}" FontSize="24" FontWeight="Bold" Foreground="#FF4ADE80" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                        <Border Style="{DynamicResource PremiumCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel>
                                    <TextBlock Text="Seriais com maior reincidência" Style="{DynamicResource SectionTitleTextStyle}" />
                                    <Button DockPanel.Dock="Right" Style="{DynamicResource SoftButtonStyle}" Content="Atualizar" Command="{Binding Dashboard.RefreshCommand}" />
                                </DockPanel>
                                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                <Border Style="{DynamicResource EmptyStateBannerStyle}"
                                        Visibility="{Binding Dashboard.HasTopSerials, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Invert'}">
                                    <TextBlock Text="Sem dados de reincidência suficientes para exibir no período atual."
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                </Border>
                                <DataGrid Style="{DynamicResource PremiumDataGridStyle}"
                                          MinHeight="160"
                                          ItemsSource="{Binding Dashboard.TopSerials}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          Margin="8"
                                          VerticalAlignment="Stretch">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Serial" Binding="{Binding SerialNumber}" Width="*" />
                                        <DataGridTextColumn Header="Ocorrências" Binding="{Binding Occurrences}" Width="130" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <TextBlock Style="{DynamicResource ModuleStatusBarTextStyle}" Text="{Binding Dashboard.StatusMessage}" />
                    </StackPanel>
                </Grid>
                <Grid Margin="0,16,0,0" Visibility="{Binding SelectedModule.Module, Converter={StaticResource ModuleVisibilityConverter}, ConverterParameter=SystemSettings}">
                    <Border Style="{DynamicResource PremiumCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Configurações do Sistema" Style="{DynamicResource SectionTitleTextStyle}" />
                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Diretórios Finder (separados por ;)" />
                                    <TextBox Text="{Binding Settings.FinderDirectories, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                                    <TextBlock Text="Endpoint Updater" />
                                    <TextBox Text="{Binding Settings.UpdaterEndpoint, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <CheckBox Content="Auto check updates" IsChecked="{Binding Settings.AutoCheckUpdates}" />
                                    <CheckBox Margin="0,8,0,0" Content="Auto abrir último módulo" IsChecked="{Binding Settings.AutoOpenLastModule}" />
                                    <TextBlock Margin="0,10,0,0" Text="Tema preferido (Dark/Light)" />
                                    <TextBox Text="{Binding Settings.PreferredTheme, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                                </StackPanel>
                            </Grid>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Style="{DynamicResource SoftButtonStyle}" Content="Recarregar" Command="{Binding Settings.LoadCommand}" />
                                <Button Margin="8,0,0,0" Style="{DynamicResource SoftButtonStyle}" Content="Salvar configurações" Command="{Binding Settings.SaveCommand}" />
                            </StackPanel>
                            <TextBlock Grid.Row="3"
                                       Style="{DynamicResource ModuleStatusBarTextStyle}"
                                       Text="{Binding Settings.StatusMessage}" />
                        </Grid>
                    </Border>
                </Grid>
                <Grid Margin="0,16,0,0" Visibility="{Binding SelectedModule.Module, Converter={StaticResource ModuleVisibilityConverter}, ConverterParameter=OfflineSync}">
                    <Border Style="{DynamicResource PremiumCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Updater Enterprise" Style="{DynamicResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="{Binding Updater.CheckSourceDescription}"
                                       TextWrapping="Wrap" />
                            <WrapPanel Margin="0,12,0,0">
                                <Border Style="{DynamicResource PremiumCardStyle}" Width="200" Margin="0,0,10,10" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="Versão local" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" />
                                        <TextBlock Text="{Binding Updater.CurrentVersion}" FontSize="22" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{DynamicResource PremiumCardStyle}" Width="200" Margin="0,0,10,10" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="Referência remota / catálogo" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" />
                                        <TextBlock Text="{Binding Updater.LatestVersion}" FontSize="22" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{DynamicResource PremiumCardStyle}" Width="220" Margin="0,0,10,10" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="Situação" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" />
                                        <TextBlock Text="{Binding Updater.UpdateStatusLabel}"
                                                   TextWrapping="Wrap"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}" />
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                            <TextBlock Text="Notas de versão" Style="{DynamicResource SectionTitleTextStyle}" Margin="0,4,0,4" />
                            <TextBlock Text="{Binding Updater.ReleaseNotes}" TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock Margin="0,10,0,0" Text="Publicação (feed)" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock Text="{Binding Updater.RemotePublishedDisplay}" Foreground="{DynamicResource PrimaryTextBrush}" />
                            <TextBlock Margin="0,10,0,0" Text="Download / pacote" Style="{DynamicResource SectionTitleTextStyle}" />
                            <TextBlock Text="{Binding Updater.DownloadUrl}" TextWrapping="Wrap" Foreground="{DynamicResource AccentBrush}" />
                            <TextBlock Margin="0,10,0,0" Text="Integridade (futura)" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock Text="{Binding Updater.IntegrityPreview}" TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" />
                            <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                <Button Style="{DynamicResource SoftButtonStyle}" Content="Verificar atualização" Command="{Binding Updater.CheckCommand}" />
                            </StackPanel>
                            <TextBlock Style="{DynamicResource ModuleStatusBarTextStyle}" Text="{Binding Updater.StatusMessage}" />
                        </StackPanel>
                    </Border>
                </Grid>
                <TextBlock Style="{DynamicResource ModuleStatusBarTextStyle}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Visibility="{Binding SelectedModule.Module, Converter={StaticResource ModuleVisibilityConverter}, ConverterParameter=LogFinder}"
                           Text="{Binding LogSearch.StatusMessage}" />
                <TextBlock Style="{DynamicResource ModuleStatusBarTextStyle}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Visibility="{Binding SelectedModule.Module, Converter={StaticResource ModuleVisibilityConverter}, ConverterParameter=TechnicalHistory}"
                           Text="{Binding TechnicalHistory.StatusMessage}" />
                <TextBlock Style="{DynamicResource ModuleStatusBarTextStyle}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Visibility="{Binding SelectedModule.Module, Converter={StaticResource ModuleVisibilityConverter}, ConverterParameter=KnowledgeBase}"
                           Text="{Binding KnowledgeBase.StatusMessage}" />
            </StackPanel>
            </ScrollViewer>
        </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" Padding="10">
            <TextBlock Text="{Binding SessionStatusLabel}"
                       Foreground="{DynamicResource MutedTextBrush}" />
        </Border>
    </Grid>
</Window>
