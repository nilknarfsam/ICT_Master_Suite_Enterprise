<Window x:Class="ICTMasterSuite.Presentation.Wpf.RegisterAnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registrar Análise Técnica"
        Height="680"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="10" Background="{DynamicResource SurfaceBrush}" Margin="0,0,0,10">
            <TextBlock Text="Registro de análise"
                       Style="{DynamicResource SectionTitleTextStyle}" />
        </Border>

        <Border Grid.Row="1" Style="{DynamicResource LoginCardStyle}" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="8">
                    <TextBlock Text="Registrar análise técnica" Style="{DynamicResource TitleTextStyle}" />
                    <TextBlock Text="Dados do log pré-carregados para agilizar o processo." Foreground="{DynamicResource MutedTextBrush}" Margin="0,4,0,12" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="8">
                        <TextBlock Text="Serial" Style="{DynamicResource LoginLabelTextStyle}" />
                        <TextBox Style="{DynamicResource LoginInputTextBoxStyle}" Text="{Binding SerialNumber}" IsReadOnly="True" Margin="0,0,0,8" />
                        <TextBlock Text="Modelo" Style="{DynamicResource LoginLabelTextStyle}" />
                        <TextBox Style="{DynamicResource LoginInputTextBoxStyle}" Text="{Binding Model}" IsReadOnly="True" Margin="0,0,0,8" />
                        <TextBlock Text="Arquivo" Style="{DynamicResource LoginLabelTextStyle}" />
                        <TextBox Style="{DynamicResource LoginInputTextBoxStyle}" Text="{Binding FileName}" IsReadOnly="True" Margin="0,0,0,8" />
                        <TextBlock Text="Tipo de log" Style="{DynamicResource LoginLabelTextStyle}" />
                        <TextBox Style="{DynamicResource LoginInputTextBoxStyle}" Text="{Binding LogType}" IsReadOnly="True" Margin="0,0,0,8" />
                        <TextBlock Text="Técnico" Style="{DynamicResource LoginLabelTextStyle}" />
                        <TextBox Style="{DynamicResource LoginInputTextBoxStyle}" Text="{Binding TechnicianName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Código de erro" Style="{DynamicResource LoginLabelTextStyle}" />
                        <TextBox Style="{DynamicResource LoginInputTextBoxStyle}" Text="{Binding ErrorCode}" IsReadOnly="True" Margin="0,0,0,8" />
                        <TextBlock Text="Descrição do erro" Style="{DynamicResource LoginLabelTextStyle}" />
                        <TextBox Text="{Binding ErrorDescription}" TextWrapping="Wrap" AcceptsReturn="True" Height="76" Margin="0,0,0,8" />
                        <TextBlock Text="Resumo" Style="{DynamicResource LoginLabelTextStyle}" />
                        <TextBox Text="{Binding Summary}" TextWrapping="Wrap" AcceptsReturn="True" Height="90" Margin="0,0,0,8" />
                        <TextBlock Text="Texto da análise" Style="{DynamicResource LoginLabelTextStyle}" />
                        <TextBox Text="{Binding AnalysisText, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Height="155" />
                    </StackPanel>
                </Grid>
                </ScrollViewer>

                <DockPanel Grid.Row="2" Margin="8,14,8,8">
                    <TextBlock DockPanel.Dock="Left"
                               Text="{Binding StatusMessage}"
                               Foreground="#FFFDA4AF"
                               VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Cancelar" Margin="0,0,10,0" Command="{Binding CancelCommand}" />
                        <Button Content="Salvar análise" Style="{DynamicResource LoginPrimaryButtonStyle}" Width="160" Command="{Binding SaveCommand}" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Padding="10" Background="{DynamicResource SurfaceBrush}" Margin="0,10,0,0">
            <TextBlock Text="Campos editáveis: técnico, resumo e texto da análise."
                       Foreground="{DynamicResource MutedTextBrush}" />
        </Border>
    </Grid>
</Window>
