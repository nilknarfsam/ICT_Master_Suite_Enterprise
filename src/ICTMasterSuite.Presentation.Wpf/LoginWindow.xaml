<Window x:Class="ICTMasterSuite.Presentation.Wpf.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:ICTMasterSuite.Presentation.Wpf.Behaviors"
        Title="ICT Master Suite | Login"
        Height="620"
        Width="1040"
        MinHeight="540"
        MinWidth="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF0F172A" Offset="0" />
                    <GradientStop Color="#FF0EA5E9" Offset="0.45" />
                    <GradientStop Color="#FF6366F1" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="56">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ICT Master Suite"
                               FontSize="40"
                               FontWeight="Bold"
                               Foreground="#FFF8FAFC" />
                    <TextBlock Text="Plataforma de Inteligência Técnica"
                               Margin="0,14,0,0"
                               FontSize="20"
                               Foreground="#FFE2E8F0" />
                    <TextBlock Margin="0,22,0,0"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="#FFCBD5E1"
                               Text="Rastreabilidade de falhas, histórico técnico consolidado e base de conhecimento corporativa para decisões ágeis e padronizadas." />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="{DynamicResource AppBackgroundBrush}">
            <Border Style="{DynamicResource LoginCardStyle}"
                    MaxWidth="430"
                    Margin="32"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#AA020617" BlurRadius="24" ShadowDepth="0" Opacity="0.35" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Login padrao -->
                    <StackPanel Grid.Row="0" VerticalAlignment="Top">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMandatoryPasswordChangeStep}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Acessar plataforma" Style="{DynamicResource TitleTextStyle}" />
                            <TextBlock Text="Use suas credenciais corporativas"
                                       Margin="0,6,0,0"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </StackPanel>

                        <TextBlock Text="Usuário" Style="{DynamicResource LoginLabelTextStyle}" />
                        <TextBox Style="{DynamicResource LoginInputTextBoxStyle}"
                                 Margin="0,0,0,12"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Senha" Style="{DynamicResource LoginLabelTextStyle}" />
                        <PasswordBox x:Name="PasswordInput"
                                     Style="{DynamicResource LoginInputPasswordBoxStyle}"
                                     Margin="0,0,0,14"
                                     behaviors:PasswordBoxAssistant.BindPassword="True"
                                     behaviors:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <CheckBox Style="{DynamicResource LoginCheckBoxStyle}"
                                  IsChecked="{Binding RememberMe}"
                                  Content="Remember me" />

                        <StackPanel Margin="0,14,0,0">
                            <Button Content="Entrar"
                                    Style="{DynamicResource LoginPrimaryButtonStyle}"
                                    Command="{Binding SignInCommand}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Troca obrigatoria de senha (bootstrap / seed) -->
                    <StackPanel Grid.Row="0" VerticalAlignment="Top">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMandatoryPasswordChangeStep}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Nova senha obrigatória" Style="{DynamicResource TitleTextStyle}" />
                            <TextBlock Text="Defina uma senha forte diferente da senha inicial."
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </StackPanel>

                        <TextBlock Text="Nova senha" Style="{DynamicResource LoginLabelTextStyle}" />
                        <PasswordBox Style="{DynamicResource LoginInputPasswordBoxStyle}"
                                     Margin="0,0,0,12"
                                     behaviors:PasswordBoxAssistant.BindPassword="True"
                                     behaviors:PasswordBoxAssistant.BoundPassword="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Confirmar nova senha" Style="{DynamicResource LoginLabelTextStyle}" />
                        <PasswordBox Style="{DynamicResource LoginInputPasswordBoxStyle}"
                                     Margin="0,0,0,14"
                                     behaviors:PasswordBoxAssistant.BindPassword="True"
                                     behaviors:PasswordBoxAssistant.BoundPassword="{Binding ConfirmNewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Margin="0,14,0,0">
                            <Button Content="Definir senha e continuar"
                                    Style="{DynamicResource LoginPrimaryButtonStyle}"
                                    Command="{Binding CompleteMandatoryPasswordChangeCommand}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,12,0,0"
                            Padding="10,8"
                            CornerRadius="8"
                            Background="#14FB7185">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#FFFDA4AF"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
